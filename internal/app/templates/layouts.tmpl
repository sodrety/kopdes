{{define "asset-head"}}
  <script src="/static/vendor/htmx-2.0.10.min.js"></script>
  <script src="/static/vendor/lucide-0.468.0.min.js"></script>
  <link rel="stylesheet" href="/static/app.css">
{{end}}

{{define "language-form"}}
      <form class="language-form" method="post" action="/language">
        <input type="hidden" name="redirect" value="{{.CurrentPath}}">
        <label>{{t .Lang "current_language"}}
          <select name="lang" onchange="this.form.submit()">
            <option value="en" {{if eq .Lang "en"}}selected{{end}}>English</option>
            <option value="id" {{if eq .Lang "id"}}selected{{end}}>Bahasa Indonesia</option>
          </select>
        </label>
      </form>
{{end}}

{{define "brand-mark"}}
      <div class="brand-mark sidebar-brand" aria-label="Kopdes">
        <img class="brand-logo" src="/static/images/lambang-koperasi.png" alt="" width="96" height="93">
        <span class="brand-text">
          <span class="brand-name">Kopdes</span>
          <span class="brand-subtitle">{{t .Lang "cooperative_system"}}</span>
        </span>
      </div>
{{end}}

{{define "admin-nav"}}
      <nav class="sidebar-nav">
        <div class="sidebar-nav-group">
          <span class="sidebar-group-label">{{t .Lang "nav_group_overview"}}</span>
          <a class="sidebar-link {{if eq .Active "dashboard"}}active{{end}}" href="/admin/dashboard" title="{{t .Lang "dashboard"}}"><i class="sidebar-icon" data-lucide="layout-dashboard"></i><span class="sidebar-label">{{t .Lang "dashboard"}}</span></a>
        </div>
        <div class="sidebar-nav-group">
          <span class="sidebar-group-label">{{t .Lang "nav_group_master_data"}}</span>
          <a class="sidebar-link {{if eq .Active "members"}}active{{end}}" href="/admin/members" title="{{t .Lang "members"}}"><i class="sidebar-icon" data-lucide="users"></i><span class="sidebar-label">{{t .Lang "members"}}</span></a>
        </div>
        <div class="sidebar-nav-group">
          <span class="sidebar-group-label">{{t .Lang "nav_group_operations"}}</span>
          <a class="sidebar-link {{if eq .Active "savings"}}active{{end}}" href="/admin/savings" title="{{t .Lang "nav_simpanan"}}"><i class="sidebar-icon" data-lucide="piggy-bank"></i><span class="sidebar-label">{{t .Lang "nav_simpanan"}}</span></a>
          <a class="sidebar-link {{if eq .Active "loan-requests"}}active{{end}}" href="/admin/loan-requests" title="{{t .Lang "nav_pinjaman_requests"}}"><i class="sidebar-icon" data-lucide="file-clock"></i><span class="sidebar-label">{{t .Lang "nav_pinjaman_requests"}}</span></a>
          <a class="sidebar-link {{if eq .Active "loans"}}active{{end}}" href="/admin/loans" title="{{t .Lang "nav_pinjaman"}}"><i class="sidebar-icon" data-lucide="landmark"></i><span class="sidebar-label">{{t .Lang "nav_pinjaman"}}</span></a>
          <a class="sidebar-link {{if eq .Active "repayments"}}active{{end}}" href="/admin/repayments" title="{{t .Lang "nav_angsuran"}}"><i class="sidebar-icon" data-lucide="receipt"></i><span class="sidebar-label">{{t .Lang "nav_angsuran"}}</span></a>
        </div>
      </nav>
{{end}}

{{define "admin-shell-start"}}
<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
{{template "asset-head" .}}
</head>
<body>
  <div class="admin-shell">
    <aside class="admin-sidebar" aria-label="{{t .Lang "admin_menu"}}">
{{template "brand-mark" .}}
{{template "admin-nav" .}}
    </aside>
    <main class="page-shell">
      <header class="admin-topbar">
        <button class="sidebar-toggle" type="button" aria-label="{{t .Lang "toggle_sidebar"}}" onclick="document.body.classList.toggle('sidebar-collapsed')">☰</button>
{{template "language-form" .}}
        <form class="logout-form" method="post" action="/logout">
          <button class="button-secondary" type="submit">{{t .Lang "logout"}}</button>
        </form>
      </header>
      <header class="page-header">
        <h1>{{t .Lang .Heading}}</h1>
        <p>{{t .Lang .Description}}</p>
      </header>
{{end}}

{{define "admin-shell-end"}}
    </main>
  </div>
  <script>if (window.lucide) { lucide.createIcons(); }</script>
</body>
</html>
{{end}}

{{define "member-nav"}}
      <nav class="member-nav">
        <a href="/member/dashboard">{{t .Lang "dashboard"}}</a>
        <a href="/member/profile">{{t .Lang "profile"}}</a>
        <a href="/member/loan-requests">{{t .Lang "loan_requests"}}</a>
      </nav>
{{end}}

{{define "member-shell-start"}}
<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
{{template "asset-head" .}}
</head>
<body>
  <main class="member-shell {{.ShellClass}}">
    <header class="member-topbar">
{{template "brand-mark" .}}
{{template "member-nav" .}}
      {{template "language-form" .}}
      <form class="logout-form" method="post" action="/logout">
        <button class="button-secondary" type="submit">{{t .Lang "logout"}}</button>
      </form>
    </header>
    <section class="page-header">
      <h1>{{t .Lang .Heading}}</h1>
      <p>{{t .Lang .Description}}</p>
    </section>
{{end}}

{{define "member-shell-end"}}
  </main>
  <script>if (window.lucide) { lucide.createIcons(); }</script>
</body>
</html>
{{end}}
