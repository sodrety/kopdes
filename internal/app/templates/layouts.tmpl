{{define "asset-head"}}
  <script src="/static/vendor/htmx-2.0.10.min.js"></script>
  <script src="/static/vendor/lucide-0.468.0.min.js"></script>
  <link rel="stylesheet" href="/static/app.css">
{{end}}

{{define "language-form"}}
      <form class="language-form" method="post" action="/language">
        <input type="hidden" name="redirect" value="{{.CurrentPath}}">
        <label>{{t .Lang "current_language"}}
          <select name="lang" onchange="this.form.submit()">
            <option value="en" {{if eq .Lang "en"}}selected{{end}}>English</option>
            <option value="id" {{if eq .Lang "id"}}selected{{end}}>Bahasa Indonesia</option>
          </select>
        </label>
      </form>
{{end}}

{{define "brand-mark"}}
      <div class="brand-mark sidebar-brand" aria-label="KKSUK PD Dharma Jaya">
        <img class="brand-logo" src="/static/images/lambang-koperasi.png" alt="" width="96" height="93">
        <span class="brand-text">
          <span class="brand-name">KKSUK PD Dharma Jaya</span>
          <span class="brand-subtitle">{{t .Lang "cooperative_system"}}</span>
        </span>
      </div>
{{end}}

{{define "toast-root"}}
  <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="true" data-default-error="{{t .Lang "toast_operation_failed"}}"></div>
{{end}}

{{define "toast-script"}}
  <script>
  (function () {
    var storeKey = "kopdes:toast";
    function region() {
      return document.getElementById("toast-region");
    }
    function textFromHTML(html) {
      var node = document.createElement("div");
      node.innerHTML = html || "";
      return (node.textContent || "").trim();
    }
    function showToast(detail) {
      var target = region();
      if (!target || !detail || !detail.message) {
        return;
      }
      var toast = document.createElement("div");
      var kind = detail.type === "success" ? "success" : "error";
      toast.className = "toast toast-" + kind;
      toast.setAttribute("role", kind === "error" ? "alert" : "status");
      toast.textContent = detail.message;
      target.appendChild(toast);
      window.setTimeout(function () {
        toast.classList.add("toast-exit");
        window.setTimeout(function () { toast.remove(); }, 180);
      }, 4200);
    }
    function persistToast(detail) {
      if (detail && detail.persist) {
        sessionStorage.setItem(storeKey, JSON.stringify(detail));
        return true;
      }
      return false;
    }
    window.addEventListener("kopdes:toast", function (event) {
      if (!persistToast(event.detail)) {
        showToast(event.detail);
      }
    });
    document.addEventListener("htmx:beforeOnLoad", function (event) {
      var xhr = event.detail && event.detail.xhr;
      var header = xhr && xhr.getResponseHeader("HX-Trigger");
      if (!header || header.charAt(0) !== "{") {
        return;
      }
      try {
        persistToast(JSON.parse(header)["kopdes:toast"]);
      } catch (err) {
      }
    });
    document.addEventListener("htmx:responseError", function (event) {
      var xhr = event.detail && event.detail.xhr;
      var message = textFromHTML(xhr && xhr.responseText) || (region() && region().dataset.defaultError);
      showToast({ type: "error", message: message });
    });
    document.addEventListener("DOMContentLoaded", function () {
      var saved = sessionStorage.getItem(storeKey);
      if (!saved) {
        return;
      }
      sessionStorage.removeItem(storeKey);
      try {
        showToast(JSON.parse(saved));
      } catch (err) {
      }
    });
  }());
  </script>
{{end}}

