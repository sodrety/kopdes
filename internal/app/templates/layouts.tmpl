{{define "admin-shell-start"}}
<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
{{template "asset-head" .}}
</head>
<body>
{{template "toast-root" .}}
  <div class="admin-shell">
    <aside class="admin-sidebar" aria-label="{{t .Lang "admin_menu"}}">
{{template "brand-mark" .}}
{{template "admin-nav" .}}
    </aside>
    <main class="page-shell">
      <header class="admin-topbar">
        <button class="sidebar-toggle" type="button" aria-label="{{t .Lang "toggle_sidebar"}}" onclick="document.body.classList.toggle('sidebar-collapsed')">☰</button>
{{template "language-form" .}}
        <form class="logout-form" method="post" action="/logout">
          <button class="button-secondary" type="submit">{{t .Lang "logout"}}</button>
        </form>
      </header>
      <header class="page-header">
        <h1>{{t .Lang .Heading}}</h1>
        <p>{{t .Lang .Description}}</p>
      </header>
{{end}}

{{define "admin-shell-end"}}
    </main>
  </div>
{{template "toast-script" .}}
  <script>if (window.lucide) { lucide.createIcons(); }</script>
</body>
</html>
{{end}}

