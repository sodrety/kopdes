{{define "login"}}
<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
{{template "asset-head" .}}
</head>
<body class="auth-page">
  <main class="auth-card">
{{template "brand-mark" .}}
    {{template "language-form" .}}
    <form method="post" action="/api/auth/login" hx-post="/api/auth/login" hx-target="#login-error" hx-swap="innerHTML">
      <label>{{t .Lang "email"}} <input name="email" type="email" autocomplete="username" required></label>
      <label>{{t .Lang "password"}} <input name="password" type="password" autocomplete="current-password" required></label>
      <button type="submit">{{t .Lang "log_in"}}</button>
    </form>
    <p id="login-error" class="form-error"></p>
  </main>
</body>
</html>
{{end}}
