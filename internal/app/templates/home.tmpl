{{define "home"}}
<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Koperasi Karyawan PT. Chandra Asri PP Site - membangun kesejahteraan bersama melalui semangat kekeluargaan dan kerjasama.">
  <title>{{.Title}}</title>
{{template "asset-head" .}}
</head>
<body class="public-page">
  <header class="public-header" id="home">
    <nav class="public-nav" aria-label="Navigasi utama">
      <a class="public-logo" href="/">
        <img src="/static/images/lambang-koperasi.png" alt="" width="80" height="78">
        <span>KOPKARLYTA</span>
      </a>
      <div class="public-links">
        <a href="#home">Beranda</a>
        <a href="#about">Tentang Kami</a>
        <a href="#vision-mission">Visi Misi</a>
        <a href="#business-units">Unit Usaha</a>
        <a href="#gallery">Galeri</a>
        <a class="public-login" href="/login"><i data-lucide="log-in"></i> Login</a>
      </div>
    </nav>
  </header>

  <main>
    <section class="public-hero">
      <div class="public-container public-hero-grid">
        <div class="public-hero-copy">
          <p class="public-eyebrow">Selamat Datang di Koperasi Kami</p>
          <h1>Koperasi Karyawan <em>PT. Chandra Asri</em> <span>PP Site</span></h1>
          <p>Membangun kesejahteraan bersama melalui semangat kekeluargaan dan kerjasama.</p>
          <div class="public-hero-actions">
            <a class="public-button" href="#about">Pelajari Lebih Lanjut</a>
            <a class="public-button" href="/login">Login</a>
          </div>
        </div>
        <div class="public-hero-visual" aria-hidden="true">
          <img src="/static/images/lambang-koperasi.png" alt="" width="220" height="214">
          <div><strong>2.000+</strong><span>Anggota aktif</span></div>
        </div>
      </div>
    </section>

    <section class="public-section" id="services">
      <div class="public-container">
        <div class="public-section-heading"><h2>Layanan Kami untuk <em>Anggota</em></h2></div>
        <div class="public-card-grid public-feature-grid">
          <article class="public-feature-card"><i data-lucide="hand-coins"></i><h3>Simpanan</h3><p>Program simpanan dengan bunga kompetitif untuk kesejahteraan anggota</p></article>
          <article class="public-feature-card"><i data-lucide="file-text"></i><h3>Pinjaman</h3><p>Pinjaman dengan syarat mudah dan bunga ringan untuk kebutuhan anggota</p></article>
          <article class="public-feature-card"><i data-lucide="chart-pie"></i><h3>SHU</h3><p>Pembagian Sisa Hasil Usaha secara transparan dan adil kepada anggota</p></article>
        </div>
      </div>
    </section>

    <section class="public-section public-about" id="about">
      <div class="public-container public-about-grid">
        <div class="public-about-visual" aria-hidden="true"><img src="/static/images/lambang-koperasi.png" alt="" width="190" height="184"></div>
        <div>
          <div class="public-section-heading public-section-heading-left"><h2>Tentang <em>Kami</em></h2></div>
          <p>Tentang Kami Koperasi kami didirikan pada tahun 1992 dengan tujuan untuk meningkatkan kesejahteraan ekonomi para karyawan PT. Chandra Asri Tbk PP Site melalui prinsip-prinsip koperasi yang mengedepankan kekeluargaan dan gotong royong.</p>
          <p>Dengan lebih dari 25 tahun pengalaman, kami telah berkembang menjadi salah satu koperasi karyawan terbaik di wilayah ini dengan jumlah anggota aktif lebih dari 2.000 orang dan aset yang terus bertumbuh setiap tahunnya.</p>
          <ul class="public-check-list">
            <li><i data-lucide="check-circle"></i> Manajemen profesional dan transparan</li>
            <li><i data-lucide="check-circle"></i> Layanan prima untuk anggota</li>
            <li><i data-lucide="check-circle"></i> Pengembangan usaha berkelanjutan</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="public-section" id="vision-mission">
      <div class="public-container">
        <div class="public-section-heading"><h2>Visi & <em>Misi</em></h2></div>
        <div class="public-card-grid public-two-grid">
          <article class="public-feature-card public-vision-card"><i data-lucide="eye"></i><h3>Visi</h3><p>"Menjadi koperasi karyawan terdepan yang berperan aktif dalam meningkatkan kesejahteraan ekonomi anggota dan berkontribusi positif bagi pembangunan masyarakat."</p></article>
          <article class="public-feature-card public-vision-card"><i data-lucide="target"></i><h3>Misi</h3><ul><li>Mengembangkan usaha koperasi yang sehat dan berkelanjutan</li><li>Meningkatkan pelayanan prima untuk kepuasan anggota</li><li>Membangun tata kelola yang profesional dan transparan</li><li>Mendorong partisipasi aktif anggota dalam pengembangan koperasi</li><li>Berkontribusi pada pemberdayaan ekonomi karyawan dan masyarakat sekitar</li></ul></article>
        </div>
      </div>
    </section>

    <section class="public-section" id="business-units">
      <div class="public-container">
        <div class="public-section-heading"><h2>Unit <em>Usaha</em> Kami</h2></div>
        <div class="public-card-grid public-feature-grid">
          <article class="public-business-card"><div class="public-business-image"><i data-lucide="landmark"></i></div><h3>Unit Simpan Pinjam</h3><p>Menyediakan layanan simpanan dan pinjaman dengan bunga kompetitif untuk anggota.</p></article>
          <article class="public-business-card"><div class="public-business-image"><i data-lucide="shopping-basket"></i></div><h3>Unit Konsumsi</h3><p>Menyediakan kebutuhan pokok dengan harga lebih murah untuk anggota.</p></article>
          <article class="public-business-card"><div class="public-business-image"><i data-lucide="plane"></i></div><h3>Unit Travel</h3><p>Layanan perjalanan dan transportasi dengan harga khusus untuk anggota.</p></article>
        </div>
      </div>
    </section>

    <section class="public-section" id="gallery">
      <div class="public-container">
        <div class="public-section-heading"><h2>Galeri <em>Kegiatan</em></h2><p>Momen-momen terbaik dalam kegiatan koperasi kami</p></div>
        <article class="public-gallery-card"><div class="public-gallery-image"><i data-lucide="users-round"></i></div><div><h3>RAT 2024</h3><p>RAPAT ANGGOTA TAHUN BUKU 2024</p></div></article>
      </div>
    </section>

    <section class="public-section public-cta">
      <div class="public-container">
        <div class="public-section-heading"><h2>Bergabunglah dengan <em>Koperasi</em> Kami Sekarang</h2><p>Manfaatkan berbagai layanan dan program yang kami sediakan untuk meningkatkan kesejahteraan Anda</p></div>
        <a class="public-button" href="/login"><i data-lucide="user-plus"></i> Daftar Menjadi Anggota</a>
      </div>
    </section>
  </main>

  <footer class="public-footer">
    <div class="public-container public-footer-grid">
      <section><h2>Koperasi Karyawan PT. Chandra Asri PP Site</h2><p>Jl. Industri PT. Chandra Asri, Kec. Cilegon, Kota Cilegon, Banten</p></section>
      <section><h2>Tautan Cepat</h2><a href="#home">Beranda</a><a href="#about">Tentang Kami</a><a href="#vision-mission">Visi Misi</a><a href="#business-units">Unit Usaha</a><a href="#gallery">Galeri</a><a href="/login">Login Anggota</a></section>
      <section><h2>Layanan</h2><a href="#services">Simpanan</a><a href="#services">Pinjaman</a><a href="#services">SHU</a><a href="#business-units">Konsumsi</a><a href="#business-units">Travel</a></section>
      <section><h2>Kontak</h2><p>(0254) 1234567</p><p>info@koperasi-chandraasri.com</p><p>Senin-Jumat: 08.00 - 16.00 WIB</p><p>Kantor Pusat: Gedung Koperasi Chandra Asri</p></section>
    </div>
    <div class="public-footer-bottom"><p>© 2025 Koperasi Karyawan PT. Chandra Asri PP Site. All rights reserved.</p><a href="https://wa.me/6285697141584">Developed by AM Dev</a></div>
  </footer>
  <script>if (window.lucide) { lucide.createIcons(); }</script>
</body>
</html>
{{end}}
