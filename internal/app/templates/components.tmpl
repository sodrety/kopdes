{{define "summary-card"}}
        <article class="summary-card"><span>{{.Label}}</span><strong>{{.Value}}</strong></article>
{{end}}

{{define "status-badge"}}
<span class="status-badge status-{{.Status}}">{{t .Lang (printf "status_%s" .Status)}}</span>
{{end}}

{{define "empty-state"}}
        <p class="empty-state">{{.}}</p>
{{end}}

{{define "form-error"}}
          <p id="{{.ID}}" class="form-error"></p>
{{end}}

{{define "member-table-cell"}}
<strong>{{.FullName}}</strong><br><span class="table-muted">{{.MemberNo}}</span>
{{end}}

{{define "table-open"}}
        <div class="table-scroll">
        <table data-enhanced-table data-page-label="{{t .Lang "table_page_status"}}" data-previous-label="{{t .Lang "previous_page"}}" data-next-label="{{t .Lang "next_page"}}">
{{end}}

{{define "table-close"}}
        </table>
        </div>
{{end}}

{{define "bar-chart"}}
        <div class="bar-chart">
          {{if .Segments.HasData}}
            {{range .Segments}}
            <div class="bar-row">
              <div class="bar-label"><span>{{t $.Lang .Label}}</span><strong>{{.Value}}</strong></div>
              <div class="bar-track" aria-label="{{t $.Lang .Label}} {{.Value}}">
                <span class="bar-fill {{.Class}}" style="width: {{.Percent}}%"></span>
              </div>
            </div>
            {{end}}
          {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
          {{end}}
        </div>
{{end}}

{{define "line-chart"}}
        <article class="line-chart-card {{.Size}}">
          <header class="line-chart-header">
            <h2>{{t .Lang .Chart.TitleKey}}{{if .Chart.TitleSuffix}} {{.Chart.TitleSuffix}}{{end}}</h2>
            <span aria-hidden="true">⋮</span>
          </header>
          <div class="line-chart-body">
            <svg class="line-chart-svg" viewBox="0 0 760 320" role="img" aria-label="{{t .Lang .Chart.TitleKey}}">
              {{range .Chart.YTicks}}
              <line class="line-chart-gridline" x1="76" y1="{{.Y}}" x2="720" y2="{{.Y}}"></line>
              <text class="line-chart-y-label" x="{{.X}}" y="{{.Y}}">{{.Label}}</text>
              {{end}}
              <line class="line-chart-axis" x1="76" y1="44" x2="76" y2="234"></line>
              <line class="line-chart-axis" x1="76" y1="234" x2="720" y2="234"></line>
              {{range .Chart.XTicks}}
              <text class="line-chart-x-label" x="{{.X}}" y="{{.Y}}">{{.Label}}</text>
              {{end}}
              {{range .Chart.Series}}
              {{$seriesClass := .Class}}
              <polyline class="line-chart-path {{.Class}}" points="{{.Points}}"></polyline>
              {{range .Dots}}
              <circle class="line-chart-point {{$seriesClass}}" cx="{{.X}}" cy="{{.Y}}" r="4"></circle>
              {{end}}
              {{end}}
            </svg>
          </div>
          <footer class="line-chart-legend">
            {{range .Chart.Series}}
            <span><i class="{{.Class}}"></i>{{t $.Lang .LabelKey}}</span>
            {{end}}
          </footer>
        </article>
{{end}}
