{{define "summary-card"}}
        <article class="summary-card"><span>{{.Label}}</span><strong>{{.Value}}</strong></article>
{{end}}

{{define "status-badge"}}
<span class="status-badge status-{{.Status}}">{{t .Lang (printf "status_%s" .Status)}}</span>
{{end}}

{{define "empty-state"}}
        <p class="empty-state">{{.}}</p>
{{end}}

{{define "form-error"}}
          <p id="{{.ID}}" class="form-error"></p>
{{end}}

{{define "member-table-cell"}}
<strong>{{.FullName}}</strong><br><span class="table-muted">{{.MemberNo}}</span>
{{end}}

{{define "table-open"}}
        <div class="table-scroll">
        <table>
{{end}}

{{define "table-close"}}
        </table>
        </div>
{{end}}

{{define "bar-chart"}}
        <div class="bar-chart">
          {{if .Segments.HasData}}
            {{range .Segments}}
            <div class="bar-row">
              <div class="bar-label"><span>{{t $.Lang .Label}}</span><strong>{{.Value}}</strong></div>
              <div class="bar-track" aria-label="{{t $.Lang .Label}} {{.Value}}">
                <span class="bar-fill {{.Class}}" style="width: {{.Percent}}%"></span>
              </div>
            </div>
            {{end}}
          {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
          {{end}}
        </div>
{{end}}
