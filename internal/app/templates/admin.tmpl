{{define "admin-withdrawal-requests"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link button-link-secondary" href="/api/admin/exports/withdrawal-requests.csv?status=pending">{{t .Lang "export_csv"}}</a>
      </section>
      <section class="panel">
        {{if .WithdrawalRequests}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "note"}}</th>
              <th>{{t $.Lang "status"}}</th>
              <th>{{t $.Lang "review"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .WithdrawalRequests}}
            <tr>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.Amount}}</td>
              <td>{{.Note}}</td>
              <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
              <td class="review-cell">
                <div class="table-actions">
                  <form method="post" action="/api/admin/withdrawal-requests/{{.ID}}/approve" hx-post="/api/admin/withdrawal-requests/{{.ID}}/approve" hx-target="#withdrawal-review-error" hx-swap="innerHTML">
                    <button type="submit">{{t $.Lang "approve"}}</button>
