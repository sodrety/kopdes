              <td>
                <form class="inline-repayment-form" method="post" action="/api/admin/loans/{{.ID}}/repayments" hx-post="/api/admin/loans/{{.ID}}/repayments" hx-target="#repayment-form-error" hx-swap="innerHTML">
                  <input name="amount" type="number" min="1" max="{{.RemainingBalance}}" placeholder="{{t $.Lang "amount"}}" aria-label="{{t $.Lang "repayment_amount"}}">
                  <input name="record_date" type="date" aria-label="{{t $.Lang "repayment_date"}}">
                  <input name="reference_no" placeholder="{{t $.Lang "reference"}}" aria-label="{{t $.Lang "reference_number"}}">
                  <input name="note" placeholder="{{t $.Lang "note"}}" aria-label="{{t $.Lang "repayment_note"}}">
                  <button type="submit">{{t $.Lang "record_repayment"}}</button>
                </form>
              </td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_active_loans")}}
        {{end}}
{{template "form-error" (dict "ID" "repayment-form-error")}}
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-repayments"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link button-link-secondary" href="/api/admin/exports/repayments.csv">{{t .Lang "export_csv"}}</a>
      </section>
      <section class="panel">
        {{if .Repayments}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "date"}}</th>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "reference"}}</th>
              <th>{{t $.Lang "note"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Repayments}}
            <tr>
              <td>{{.RecordDate}}</td>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.Amount}}</td>
              <td>{{.ReferenceNo}}</td>
              <td>{{.Note}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_repayments")}}
        {{end}}
      </section>
{{template "admin-shell-end" .}}
{{end}}
