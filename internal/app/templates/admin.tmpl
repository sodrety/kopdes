{{define "admin-dashboard"}}
{{template "admin-shell-start" .}}
      <section class="summary-grid">
{{template "summary-card" (dict "Label" (t .Lang "total_members") "Value" .Summary.TotalMembers)}}
{{template "summary-card" (dict "Label" (t .Lang "active_members") "Value" .Summary.ActiveMembers)}}
{{template "summary-card" (dict "Label" (t .Lang "total_savings") "Value" (nominal .Summary.TotalSavings))}}
{{template "summary-card" (dict "Label" (t .Lang "active_loans") "Value" .Summary.ActiveLoans)}}
{{template "summary-card" (dict "Label" (t .Lang "outstanding_loan") "Value" (nominal .Summary.TotalOutstandingLoan))}}
{{template "summary-card" (dict "Label" (t .Lang "pending_requests") "Value" .Summary.PendingLoanRequests)}}
      </section>
      <section class="dashboard-line-grid">
{{template "line-chart" (dict "Lang" .Lang "Chart" .Reports.SavingsLoanComparison "Size" "line-chart-wide")}}
{{template "line-chart" (dict "Lang" .Lang "Chart" .Reports.BalanceTrend "Size" "line-chart-compact")}}
      </section>
      <section class="dashboard-home-grid">
        <article class="panel dashboard-activity-card">
          <header class="panel-header">
            <h2>{{t .Lang "recent_activity"}}</h2>
          </header>
          {{if .Reports.Repayments}}
{{template "table-open" .}}
            <thead>
              <tr>
                <th>{{t $.Lang "date"}}</th>
                <th>{{t $.Lang "category"}}</th>
                <th>{{t $.Lang "description"}}</th>
                <th>{{t $.Lang "amount"}}</th>
              </tr>
            </thead>
            <tbody>
              {{range .Reports.Repayments}}
              <tr>
                <td>{{.RecordDate}}</td>
                <td>{{t $.Lang "repayment"}}</td>
                <td>{{.FullName}} - {{.ReferenceNo}}</td>
                <td>{{nominal .Amount}}</td>
              </tr>
              {{end}}
            </tbody>
{{template "table-close" .}}
          {{else if .Reports.Loans}}
{{template "table-open" .}}
            <thead>
              <tr>
                <th>{{t $.Lang "date"}}</th>
                <th>{{t $.Lang "category"}}</th>
                <th>{{t $.Lang "description"}}</th>
                <th>{{t $.Lang "amount"}}</th>
              </tr>
            </thead>
            <tbody>
              {{range .Reports.Loans}}
              <tr>
                <td>{{.CreatedAt}}</td>
                <td>{{t $.Lang "pinjaman"}}</td>
                <td>{{.FullName}}</td>
                <td>{{nominal .ApprovedAmount}}</td>
              </tr>
              {{end}}
            </tbody>
{{template "table-close" .}}
          {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
          {{end}}
        </article>
        <article class="panel dashboard-quick-card">
          <header class="panel-header">
            <h2>{{t .Lang "quick_actions"}}</h2>
          </header>
          <div class="dashboard-quick-list">
            <a href="/admin/members/new"><i data-lucide="user-plus"></i><span>{{t .Lang "create_member"}}</span></a>
            <a href="/admin/savings/new"><i data-lucide="piggy-bank"></i><span>{{t .Lang "record_saving"}}</span></a>
            <a href="/admin/loan-requests"><i data-lucide="file-clock"></i><span>{{t .Lang "loan_requests"}}</span></a>
            <a href="/admin/reports/balance"><i data-lucide="scale"></i><span>{{t .Lang "balance_report"}}</span></a>
          </div>
        </article>
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-reports"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link button-link-secondary" href="/admin/reports/balance">{{t .Lang "balance_report"}}</a>
      </section>
      <section class="chart-grid">
        <article class="panel chart-panel">
          <h2>{{t .Lang "simpanan_by_category"}}</h2>
{{template "bar-chart" (dict "Lang" .Lang "Segments" .Reports.SavingsByCategory)}}
        </article>
        <article class="panel chart-panel">
          <h2>{{t .Lang "penarikan_by_status"}}</h2>
{{template "bar-chart" (dict "Lang" .Lang "Segments" .Reports.WithdrawalsByStatus)}}
        </article>
        <article class="panel chart-panel">
          <h2>{{t .Lang "pinjaman_exposure"}}</h2>
{{template "bar-chart" (dict "Lang" .Lang "Segments" .Reports.LoanExposure)}}
        </article>
        <article class="panel chart-panel">
          <h2>{{t .Lang "angsuran_progress"}}</h2>
{{template "bar-chart" (dict "Lang" .Lang "Segments" .Reports.RepaymentProgress)}}
        </article>
      </section>
      <section class="panel">
        <h2>{{t .Lang "simpanan_report"}}</h2>
        {{if .Reports.SavingsByMember}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "member_type"}}</th>
              <th>{{t $.Lang "simpanan_pokok"}}</th>
              <th>{{t $.Lang "simpanan_wajib"}}</th>
              <th>{{t $.Lang "simpanan_sukarela"}}</th>
              <th>{{t $.Lang "total"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Reports.SavingsByMember}}
            <tr>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.MemberTypeLabel}}</td>
              <td>{{nominal .Pokok}}</td>
              <td>{{nominal .Wajib}}</td>
              <td>{{nominal .Sukarela}}</td>
              <td>{{nominal .Total}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
        {{end}}
      </section>
      <section class="panel">
        <h2>{{t .Lang "penarikan_report"}}</h2>
        {{if .Reports.WithdrawalsByMember}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "member_type"}}</th>
              <th>{{t $.Lang "status_pending"}}</th>
              <th>{{t $.Lang "status_approved"}}</th>
              <th>{{t $.Lang "status_rejected"}}</th>
              <th>{{t $.Lang "total"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Reports.WithdrawalsByMember}}
            <tr>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.MemberTypeLabel}}</td>
              <td>{{.Pending}}</td>
              <td>{{.Approved}}</td>
              <td>{{.Rejected}}</td>
              <td>{{nominal .Total}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
        {{end}}
      </section>
      <section class="panel">
        <h2>{{t .Lang "pinjaman_report"}}</h2>
        {{if .Reports.Loans}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "member_type"}}</th>
              <th>{{t $.Lang "approved_amount"}}</th>
              <th>{{t $.Lang "start_date"}}</th>
			  <th>{{t $.Lang "monthly_admin_fee"}}</th>
              <th>{{t $.Lang "total_obligation"}}</th>
              <th>{{t $.Lang "monthly_installment"}}</th>
              <th>{{t $.Lang "remaining_balance"}}</th>
              <th>{{t $.Lang "next_due_date"}}</th>
              <th>{{t $.Lang "final_due_date"}}</th>
              <th>{{t $.Lang "status"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Reports.Loans}}
            <tr>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.MemberTypeLabel}}</td>
              <td>{{nominal .ApprovedAmount}}</td>
              <td>{{.StartDate}}</td>
			  <td>{{nominal .MonthlyAdminFee}}</td>
              <td>{{nominal .TotalObligation}}</td>
              <td>{{nominal .MonthlyInstallment}}</td>
              <td>{{nominal .RemainingBalance}}</td>
              <td>{{.NextDueDate}}</td>
              <td>{{.FinalDueDate}}</td>
              <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
        {{end}}
      </section>
      <section class="panel">
        <h2>{{t .Lang "angsuran_report"}}</h2>
        {{if .Reports.Repayments}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "date"}}</th>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "member_type"}}</th>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "reference"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Reports.Repayments}}
            <tr>
              <td>{{.RecordDate}}</td>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{.MemberTypeLabel}}</td>
              <td>{{nominal .Amount}}</td>
              <td>{{.ReferenceNo}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_report_data")}}
        {{end}}
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-balance-report"}}
{{template "admin-shell-start" .}}
      <section class="balance-report-card">
        <header class="balance-report-card-header">
          <h2>{{t .Lang "financial_balance_report"}}</h2>
          <div class="balance-export-actions">
            <a class="button-link button-link-secondary" href="/admin/reports/balance?export=csv">{{t .Lang "export_csv"}}</a>
            <a class="button-link button-link-secondary" href="/admin/reports/balance?export=pdf">{{t .Lang "export_pdf"}}</a>
          </div>
        </header>
        <div class="balance-report-card-body">
          <section class="balance-health-alert">
            <div>
              <span>{{t .Lang "financial_health_indicator"}}</span>
              <p>{{t .Lang "liability_asset_ratio"}} <strong>{{.Report.LiabilityRatio}}%</strong> - {{t .Lang "status"}}: <strong>{{t .Lang (printf "health_%s" .Report.HealthStatus)}}</strong></p>
            </div>
            <i data-lucide="triangle-alert"></i>
          </section>

          <section class="balance-kpi-grid">
            <article class="balance-kpi-card balance-kpi-primary">
              <span>{{t .Lang "total_assets"}}</span>
              <strong>Rp {{nominal .Report.TotalAssets}}</strong>
              <small>{{t .Lang "cash_plus_loan_receivable"}}</small>
            </article>
            <article class="balance-kpi-card balance-kpi-warning">
              <span>{{t .Lang "total_liabilities"}}</span>
              <strong>Rp {{nominal .Report.TotalLiabilities}}</strong>
              <small>{{t .Lang "member_savings"}}</small>
            </article>
            <article class="balance-kpi-card balance-kpi-success">
              <span>{{t .Lang "total_equity"}}</span>
              <strong>Rp {{nominal .Report.TotalEquity}}</strong>
              <small>{{t .Lang "assets_minus_liabilities"}}</small>
            </article>
          </section>

          <section class="balance-detail-card">
            <h3><i data-lucide="scale"></i> {{t .Lang "balance_detail"}}</h3>
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "category"}}</th>
              <th>{{t $.Lang "amount_rp"}}</th>
            </tr>
          </thead>
          <tbody>
            <tr class="balance-section-row">
              <td>{{t $.Lang "assets"}}</td>
              <td>Rp {{nominal .Report.TotalAssets}}</td>
            </tr>
            <tr>
              <td><span class="balance-row-icon balance-positive-dot"></span>{{t $.Lang "cash_in_out"}}</td>
              <td>Rp {{nominal .Report.CashAsset}}</td>
            </tr>
            <tr>
              <td><span class="balance-row-icon balance-negative-dot"></span>{{t $.Lang "loan_receivable"}}</td>
              <td>Rp {{nominal .Report.LoanReceivable}}</td>
            </tr>
            <tr class="balance-section-row">
              <td>{{t $.Lang "liabilities"}}</td>
              <td>Rp {{nominal .Report.TotalLiabilities}}</td>
            </tr>
            <tr>
              <td><span class="balance-row-icon balance-warning-dot"></span>{{t $.Lang "member_savings"}}</td>
              <td>Rp {{nominal .Report.TotalSavings}}</td>
            </tr>
            <tr class="balance-section-row">
              <td>{{t $.Lang "equity"}}</td>
              <td>Rp {{nominal .Report.TotalEquity}}</td>
            </tr>
            <tr class="balance-total-row">
              <td>{{t $.Lang "balance_equation"}}</td>
              <td>Rp {{nominal .Report.TotalAssets}} = Rp {{nominal .Report.TotalAssets}}</td>
            </tr>
          </tbody>
{{template "table-close" .}}
          </section>

          <section class="balance-meta-grid">
            <article class="balance-meta-card balance-meta-info">
              <h3>{{t .Lang "information"}}</h3>
              <p>{{t .Lang "report_period_all"}}</p>
              <p>{{t .Lang "printed_at"}} {{.Report.PrintedAt}}</p>
            </article>
            <article class="balance-meta-card balance-meta-secondary">
              <h3>{{t .Lang "composition"}}</h3>
              <p>{{t .Lang "cash"}}: {{nominal .Report.CashAsset}}</p>
              <p>{{t .Lang "receivables"}}: {{nominal .Report.LoanReceivable}}</p>
            </article>
          </section>
        </div>
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-profit-loss-report"}}
{{template "admin-shell-start" .}}
      <section class="profit-period-toolbar">
        <div class="profit-period-badge"><i data-lucide="calendar-days"></i> {{t .Lang "period"}} {{.Report.PeriodStart}} - {{.Report.PeriodEnd}}</div>
        <form class="profit-period-form" method="get" action="/admin/reports/profit-loss">
          <label>
            <span>{{t .Lang "date_from"}}</span>
            <input type="date" name="date_from" value="{{.Period.DateFrom}}">
          </label>
          <label>
            <span>{{t .Lang "date_to"}}</span>
            <input type="date" name="date_to" value="{{.Period.DateTo}}">
          </label>
          <button class="button-link profit-filter-button" type="submit">{{t .Lang "apply_filters"}}</button>
          <a class="button-link button-link-secondary profit-reset-button" href="/admin/reports/profit-loss">{{t .Lang "reset"}}</a>
        </form>
      </section>

      <section class="profit-kpi-grid">
        <article class="profit-kpi-card profit-kpi-income">
          <span>{{t .Lang "total_income"}}</span>
          <strong>Rp {{nominal .Report.TotalIncome}}</strong>
          <small>{{.Report.IncomePercent}}%</small>
        </article>
        <article class="profit-kpi-card profit-kpi-cost">
          <span>{{t .Lang "total_cost"}}</span>
          <strong>Rp {{nominal .Report.TotalCost}}</strong>
          <small>{{.Report.CostPercent}}%</small>
        </article>
        <article class="profit-kpi-card profit-kpi-net">
          <span>{{t .Lang "net_profit"}}</span>
          <strong>+ Rp {{nominal .Report.NetProfit}}</strong>
          <small>{{t .Lang "margin"}} {{.Report.MarginPercent}}%</small>
        </article>
      </section>

      <section class="profit-card">
        <header class="profit-card-header"><h2><i data-lucide="download"></i> {{t .Lang "data_export"}}</h2></header>
        <div class="profit-card-body">
          <div class="profit-action-row">
            <a class="button-link profit-export-button" href="{{.ExportCSVURL}}">{{t .Lang "export_csv"}}</a>
            <a class="button-link profit-export-button" href="{{.ExportPDFURL}}">{{t .Lang "export_pdf"}}</a>
            <button class="profit-print-button" type="button" onclick="window.print()">{{t .Lang "print_report"}}</button>
          </div>
        </div>
      </section>

      <section class="profit-tabs-card">
        <header class="profit-tabs-header">
          <span class="active"><i data-lucide="banknote"></i> {{t .Lang "income_detail"}}</span>
          <span><i data-lucide="receipt-text"></i> {{t .Lang "cost_detail"}}</span>
          <span><i data-lucide="chart-column"></i> {{t .Lang "monthly_breakdown"}}</span>
        </header>
        <div class="profit-tabs-body">
          <section class="profit-detail-column">
            <h2><i data-lucide="list"></i> {{t .Lang "income_breakdown"}}</h2>
            <p>{{t .Lang "total_income_transactions"}} {{.Report.IncomeTransactions}} {{t .Lang "income_transactions"}}</p>
            {{if .Report.IncomeTransactions}}
            <div class="profit-total-line"><span>{{t .Lang "verified_cash_in"}}</span><strong>Rp {{nominal .Report.TotalIncome}}</strong></div>
            {{else}}
            <p class="profit-empty">{{t .Lang "no_income_data_for_period"}}</p>
            {{end}}
          </section>
          <section class="profit-detail-column">
            <h2><i data-lucide="receipt"></i> {{t .Lang "cost_breakdown"}}</h2>
            <p>{{t .Lang "total_cost_transactions"}} {{.Report.CostTransactions}} {{t .Lang "cost_transactions"}}</p>
            {{if .Report.CostTransactions}}
            <div class="profit-total-line"><span>{{t .Lang "verified_cash_out"}}</span><strong>Rp {{nominal .Report.TotalCost}}</strong></div>
            {{else}}
            <p class="profit-empty">{{t .Lang "no_cost_data_for_period"}}</p>
            {{end}}
          </section>
        </div>
      </section>

      <section class="profit-insights-card">
        <header class="profit-insights-header"><h2><i data-lucide="lightbulb"></i> {{t .Lang "insights_analysis"}}</h2></header>
        <div class="profit-insights-grid">
          <article class="profit-insight-box profit-insight-info">
            <h3>{{t .Lang "financial_composition"}}</h3>
            <p>{{t .Lang "income_cost_ratio"}}</p>
            <p>{{t .Lang "income"}} {{.Report.IncomePercent}}%</p>
            <p>{{t .Lang "cost"}} {{.Report.CostPercent}}%</p>
            <p>{{t .Lang "profit_margin"}} {{.Report.MarginPercent}}%</p>
          </article>
          <article class="profit-insight-box profit-insight-primary">
            <h3>{{t .Lang "monthly_performance"}}</h3>
            <p>{{t .Lang "monthly_average"}}</p>
            <strong>Rp {{nominal .Report.MonthlyAverage}}</strong>
          </article>
        </div>
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-members"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link" href="/admin/members/new">{{t .Lang "create_member"}}</a>
      </section>
      <section class="panel">
          <h2>{{t .Lang "member_list"}}</h2>
          {{if .Members}}
{{template "table-open" .}}
            <thead>
              <tr>
                <th>{{t $.Lang "member_no"}}</th>
                <th>{{t $.Lang "name"}}</th>
                <th>{{t $.Lang "member_type"}}</th>
                <th>{{t $.Lang "status"}}</th>
              </tr>
            </thead>
            <tbody>
              {{range .Members}}
              <tr>
                <td><a href="/admin/members/{{.ID}}">{{.MemberNo}}</a></td>
                <td>{{.FullName}}</td>
                <td>{{.MemberTypeLabel}}</td>
                <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
              </tr>
              {{end}}
            </tbody>
{{template "table-close" .}}
          {{else}}
{{template "empty-state" (t .Lang "no_members")}}
          {{end}}
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-member-new"}}
{{template "admin-shell-start" .}}
      <section class="panel narrow-panel">
        <form method="post" action="/api/admin/members" hx-post="/api/admin/members" hx-target="#member-form-error" hx-swap="innerHTML">
          <label>{{t .Lang "member_number"}} <input name="member_no" required></label>
          <label>{{t .Lang "full_name"}} <input name="full_name" required></label>
          <label>{{t .Lang "phone"}} <input name="phone"></label>
          <label>{{t .Lang "address"}} <input name="address"></label>
          <label>{{t .Lang "join_date"}} <input name="join_date" type="date" required></label>
          <label>{{t .Lang "member_type"}}
            <select name="member_type">
              <option value="daily_worker">{{t .Lang "member_type_daily_worker"}}</option>
              <option value="employee" selected>{{t .Lang "member_type_employee"}}</option>
              <option value="self_employed">{{t .Lang "member_type_self_employed"}}</option>
            </select>
          </label>
          <label>{{t .Lang "status"}}
            <select name="status">
              <option value="active">{{t .Lang "active"}}</option>
              <option value="inactive">{{t .Lang "inactive"}}</option>
              <option value="suspended">{{t .Lang "suspended"}}</option>
            </select>
          </label>
          <div class="form-section">
            <h3>{{t .Lang "member_login"}}</h3>
            <label>{{t .Lang "email"}} <input name="email" type="email" autocomplete="off"></label>
            <label>{{t .Lang "password"}} <input name="password" type="password" autocomplete="new-password"></label>
          </div>
          <button type="submit">{{t .Lang "create_member"}}</button>
        </form>
{{template "form-error" (dict "ID" "member-form-error")}}
      </section>
{{template "admin-shell-end" .}}
{{end}}

{{define "admin-savings"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link" href="/admin/savings/new">{{t .Lang "record_saving"}}</a>
        <a class="button-link button-link-secondary" href="{{.ExportPath}}">{{t .Lang "export_csv"}}</a>
      </section>
      <section class="panel">
        <h2>{{t .Lang "saving_records"}}</h2>
        <form class="filter-form" method="get" action="/admin/savings">
          <label>{{t .Lang "member"}}
            <select name="member_id">
              <option value="">{{t .Lang "all_members"}}</option>
              {{range .Members}}
              <option value="{{.ID}}" {{if eq $.Filters.MemberID .ID}}selected{{end}}>{{.FullName}} - {{.MemberNo}}</option>
              {{end}}
            </select>
          </label>
          <label>{{t .Lang "saving_category"}}
            <select name="category">
              <option value="">{{t .Lang "all_categories"}}</option>
              <option value="pokok" {{if eq .Filters.Category "pokok"}}selected{{end}}>{{t .Lang "simpanan_pokok"}}</option>
              <option value="wajib" {{if eq .Filters.Category "wajib"}}selected{{end}}>{{t .Lang "simpanan_wajib"}}</option>
              <option value="sukarela" {{if eq .Filters.Category "sukarela"}}selected{{end}}>{{t .Lang "simpanan_sukarela"}}</option>
            </select>
          </label>
          <label>{{t .Lang "type"}}
            <select name="type">
              <option value="">{{t .Lang "all_types"}}</option>
              <option value="deposit" {{if eq .Filters.Type "deposit"}}selected{{end}}>{{t .Lang "deposit"}}</option>
              <option value="withdrawal" {{if eq .Filters.Type "withdrawal"}}selected{{end}}>{{t .Lang "withdrawal"}}</option>
            </select>
          </label>
          <label>{{t .Lang "date_from"}} <input name="date_from" type="date" value="{{.Filters.DateFrom}}"></label>
          <label>{{t .Lang "date_to"}} <input name="date_to" type="date" value="{{.Filters.DateTo}}"></label>
          <button type="submit">{{t .Lang "apply_filters"}}</button>
        </form>
        {{if .Savings}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "date"}}</th>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "saving_category"}}</th>
              <th>{{t $.Lang "type"}}</th>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "reference"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Savings}}
            <tr>
              <td>{{.RecordDate}}</td>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{t $.Lang (printf "simpanan_%s" .Category)}}</td>
              <td>{{t $.Lang .Type}}</td>
              <td>{{nominal .Amount}}</td>
              <td>{{.ReferenceNo}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_saving_records")}}
        {{end}}
      </section>
{{template "admin-shell-end" .}}
