{{template "admin-shell-end" .}}
{{end}}

{{define "admin-repayments"}}
{{template "admin-shell-start" .}}
      <section class="page-actions">
        <a class="button-link button-link-secondary" href="/api/admin/exports/repayments.csv">{{t .Lang "export_csv"}}</a>
      </section>
      <section class="panel">
        <form class="filter-form" method="get" action="/admin/repayments">
          <label>{{t .Lang "search_member"}} <input name="search" value="{{.Filters.Search}}" placeholder="{{t .Lang "member"}}"></label>
          <button type="submit">{{t .Lang "search"}}</button>
        </form>
        {{if .Repayments}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "date"}}</th>
              <th>{{t $.Lang "member"}}</th>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "reference"}}</th>
              <th>{{t $.Lang "note"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .Repayments}}
            <tr>
              <td>{{.RecordDate}}</td>
              <td>{{template "member-table-cell" .}}</td>
              <td>{{nominal .Amount}}</td>
              <td>{{.ReferenceNo}}</td>
              <td>{{.Note}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_repayments")}}
        {{end}}
      </section>
{{template "admin-shell-end" .}}
{{end}}
