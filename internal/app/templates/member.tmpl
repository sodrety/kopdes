{{define "member-dashboard"}}
{{template "member-shell-start" .}}
    <section class="summary-grid">
{{template "summary-card" (dict "Label" (t .Lang "saving_balance") "Value" (nominal .Dashboard.SavingBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "remaining_loan") "Value" (nominal .Dashboard.RemainingLoanBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "next_due_date") "Value" .Dashboard.EarliestDueDate)}}
{{template "summary-card" (dict "Label" (t .Lang "final_due_date") "Value" .Dashboard.LatestFinalDueDate)}}
{{if .Dashboard.HasOverdueLoan}}{{template "summary-card" (dict "Label" (t .Lang "payment_status") "Value" (t .Lang "overdue"))}}{{end}}
{{if .Dashboard.ActiveLoan}}
{{template "summary-card" (dict "Label" (t .Lang "active_loan") "Value" (nominal .Dashboard.ActiveLoan.ApprovedAmount))}}
{{else}}
{{template "summary-card" (dict "Label" (t .Lang "active_loan") "Value" (t .Lang "none"))}}
{{end}}
    </section>
    <section class="panel">
      <h2>{{t .Lang "loan_request_status"}}</h2>
      {{if .Dashboard.LoanRequests}}
{{template "table-open" .}}
        <thead>
          <tr>
            <th>{{t $.Lang "amount"}}</th>
            <th>{{t $.Lang "loan_type"}}</th>
            <th>{{t $.Lang "duration"}}</th>
            <th>{{t $.Lang "status"}}</th>
            <th>{{t $.Lang "purpose"}}</th>
            <th>{{t $.Lang "rejection_reason"}}</th>
          </tr>
        </thead>
        <tbody>
          {{range .Dashboard.LoanRequests}}
          <tr>
            <td>{{nominal .RequestedAmount}}</td>
            <td>{{template "loan-type-label" (dict "Lang" $.Lang "LoanType" .LoanType "LegacyTerms" .LegacyTerms)}}</td>
            <td>{{.DurationMonths}} {{t $.Lang "months"}}</td>
            <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
            <td>{{.Purpose}}</td>
            <td>{{.RejectionReason}}</td>
          </tr>
          {{end}}
        </tbody>
{{template "table-close" .}}
      {{else}}
{{template "empty-state" (t .Lang "no_loan_requests")}}
      {{end}}
    </section>
    <section class="panel">
      <h2>{{t .Lang "latest_saving_records"}}</h2>
      {{if .Dashboard.LatestSavings}}
{{template "table-open" .}}
        <thead>
          <tr>
            <th>{{t $.Lang "date"}}</th>
            <th>{{t $.Lang "saving_category"}}</th>
            <th>{{t $.Lang "type"}}</th>
            <th>{{t $.Lang "amount"}}</th>
            <th>{{t $.Lang "reference"}}</th>
          </tr>
        </thead>
        <tbody>
          {{range .Dashboard.LatestSavings}}
          <tr>
            <td>{{.RecordDate}}</td>
            <td>{{t $.Lang (printf "simpanan_%s" .Category)}}</td>
            <td>{{t $.Lang .Type}}</td>
            <td>{{nominal .Amount}}</td>
            <td>{{.ReferenceNo}}</td>
          </tr>
          {{end}}
        </tbody>
{{template "table-close" .}}
      {{else}}
{{template "empty-state" (t .Lang "no_saving_records")}}
      {{end}}
    </section>
    <section class="panel">
      <h2>{{t .Lang "latest_repayment_records"}}</h2>
      {{if .Dashboard.LatestRepayments}}
{{template "table-open" .}}
        <thead>
          <tr>
            <th>{{t $.Lang "date"}}</th>
            <th>{{t $.Lang "amount"}}</th>
            <th>{{t $.Lang "reference"}}</th>
          </tr>
        </thead>
        <tbody>
          {{range .Dashboard.LatestRepayments}}
          <tr>
            <td>{{.RecordDate}}</td>
            <td>{{nominal .Amount}}</td>
            <td>{{.ReferenceNo}}</td>
          </tr>
          {{end}}
        </tbody>
{{template "table-close" .}}
      {{else}}
{{template "empty-state" (t .Lang "no_repayment_records")}}
      {{end}}
    </section>
{{template "member-shell-end" .}}
{{end}}

{{define "member-profile"}}
{{template "member-shell-start" .}}
    <section class="summary-grid">
{{template "summary-card" (dict "Label" (t .Lang "saving_balance") "Value" (nominal .Summary.CurrentBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "simpanan_pokok") "Value" (nominal .Summary.PokokBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "simpanan_wajib") "Value" (nominal .Summary.WajibBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "simpanan_sukarela") "Value" (nominal .Summary.SukarelaBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "total_deposits") "Value" (nominal .Summary.TotalDeposit))}}
{{template "summary-card" (dict "Label" (t .Lang "total_withdrawals") "Value" (nominal .Summary.TotalWithdrawal))}}
    </section>
    {{if .OutstandingLoans}}
    <section class="panel">
      <h2>{{t .Lang "outstanding_loans"}}</h2>
      {{range .OutstandingLoans}}
      {{if eq .Status "active"}}<p>{{t $.Lang "active_loan"}}</p>{{end}}
      <div class="detail-grid">
        <div><span>{{t $.Lang "loan_type"}}</span><strong>{{template "loan-type-label" (dict "Lang" $.Lang "LoanType" .LoanType "LegacyTerms" .LegacyTerms)}}</strong></div>
        <div><span>{{t $.Lang "approved_amount"}}</span><strong>{{nominal .ApprovedAmount}}</strong></div>
        <div><span>{{t $.Lang "monthly_installment"}}</span><strong>{{nominal .MonthlyInstallment}}</strong></div>
        <div><span>{{t $.Lang "remaining_balance"}}</span><strong>{{nominal .RemainingBalance}}</strong></div>
        <div><span>{{t $.Lang "next_due_date"}}</span><strong>{{.NextDueDate}}</strong></div>
        <div><span>{{t $.Lang "final_due_date"}}</span><strong>{{.FinalDueDate}}</strong></div>
        <div><span>{{t $.Lang "status"}}</span><strong>{{t $.Lang (printf "status_%s" .Status)}}</strong></div>
      </div>
      {{end}}
    </section>
    {{end}}
    <section class="panel detail-grid">
      <div><span>{{t .Lang "member_no"}}</span><strong>{{.Member.MemberNo}}</strong></div>
      <div><span>{{t .Lang "full_name"}}</span><strong>{{.Member.FullName}}</strong></div>
      <div><span>{{t .Lang "phone"}}</span><strong>{{.Member.Phone}}</strong></div>
      <div><span>{{t .Lang "address"}}</span><strong>{{.Member.Address}}</strong></div>
      <div><span>{{t .Lang "join_date"}}</span><strong>{{.Member.JoinDate}}</strong></div>
      <div><span>{{t .Lang "member_type"}}</span><strong>{{.Member.MemberTypeLabel}}</strong></div>
      <div><span>{{t .Lang "status"}}</span><strong>{{t .Lang .Member.Status}}</strong></div>
    </section>
    <section class="panel">
      <h2>{{t .Lang "saving_history"}}</h2>
      {{if .Savings}}
{{template "table-open" .}}
        <thead>
          <tr>
            <th>{{t $.Lang "date"}}</th>
            <th>{{t $.Lang "saving_category"}}</th>
            <th>{{t $.Lang "type"}}</th>
            <th>{{t $.Lang "amount"}}</th>
            <th>{{t $.Lang "reference"}}</th>
            <th>{{t $.Lang "note"}}</th>
          </tr>
        </thead>
        <tbody>
          {{range .Savings}}
          <tr>
            <td>{{.RecordDate}}</td>
            <td>{{t $.Lang (printf "simpanan_%s" .Category)}}</td>
            <td>{{t $.Lang .Type}}</td>
            <td>{{nominal .Amount}}</td>
            <td>{{.ReferenceNo}}</td>
            <td>{{.Note}}</td>
          </tr>
          {{end}}
        </tbody>
{{template "table-close" .}}
      {{else}}
{{template "empty-state" (t .Lang "no_saving_records")}}
      {{end}}
    </section>
    <section class="panel">
      <h2>{{t .Lang "repayment_history"}}</h2>
      {{if .Repayments}}
{{template "table-open" .}}
        <thead>
          <tr>
            <th>{{t $.Lang "date"}}</th>
            <th>{{t $.Lang "amount"}}</th>
            <th>{{t $.Lang "reference"}}</th>
            <th>{{t $.Lang "note"}}</th>
          </tr>
        </thead>
        <tbody>
          {{range .Repayments}}
          <tr>
            <td>{{.RecordDate}}</td>
            <td>{{nominal .Amount}}</td>
            <td>{{.ReferenceNo}}</td>
            <td>{{.Note}}</td>
          </tr>
          {{end}}
        </tbody>
{{template "table-close" .}}
      {{else}}
{{template "empty-state" (t .Lang "no_repayments")}}
      {{end}}
    </section>
{{template "member-shell-end" .}}
{{end}}

{{define "member-withdrawal-requests"}}
{{template "member-shell-start" .}}
    <section class="summary-grid">
{{template "summary-card" (dict "Label" (t .Lang "simpanan_sukarela") "Value" (nominal .Summary.SukarelaBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "available_withdrawal_balance") "Value" (nominal .Summary.AvailableWithdrawalBalance))}}
{{template "summary-card" (dict "Label" (t .Lang "saving_balance") "Value" (nominal .Summary.CurrentBalance))}}
    </section>
    <section class="two-column">
      <article class="panel">
        <h2>{{t .Lang "submit_withdrawal_request"}}</h2>
        <form method="post" action="/api/member/withdrawal-requests" hx-post="/api/member/withdrawal-requests" hx-target="#withdrawal-request-error" hx-swap="innerHTML">
          <label>{{t .Lang "amount"}}
            <input name="amount" type="text" inputmode="numeric" placeholder="Rp 0" data-rupiah-input data-rupiah-group="{{if eq .Lang "id"}}.{{else}},{{end}}" data-rupiah-invalid="{{t .Lang "error_invalid_rupiah_amount"}}" data-rupiah-max="{{.Summary.AvailableWithdrawalBalance}}" data-rupiah-max-invalid="{{t .Lang "error_withdrawal_amount_over_available"}}" aria-describedby="withdrawal-amount-hint" aria-errormessage="withdrawal-amount-error" required>
            <small id="withdrawal-amount-hint">{{t .Lang "rupiah_input_hint"}}</small>
            <small id="withdrawal-amount-error" class="form-error-message" aria-live="polite" hidden></small>
          </label>
          <label>{{t .Lang "note"}} <input name="note"></label>
          <button type="submit">{{t .Lang "submit_withdrawal_request"}}</button>
        </form>
{{template "form-error" (dict "ID" "withdrawal-request-error")}}
      </article>
      <article class="panel">
        <h2>{{t .Lang "withdrawal_request_history"}}</h2>
        {{if .WithdrawalRequests}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "status"}}</th>
              <th>{{t $.Lang "note"}}</th>
              <th>{{t $.Lang "rejection_reason"}}</th>
              <th>{{t $.Lang "review"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .WithdrawalRequests}}
            <tr>
              <td>{{nominal .Amount}}</td>
              <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
              <td>{{.Note}}</td>
              <td>{{.RejectionReason}}</td>
              <td>{{if .CurrentApprovalStage}}{{t $.Lang "awaiting"}} {{t $.Lang (printf "role_%s" .CurrentApprovalStage)}}{{end}}{{if .LatestDecision}}<div>{{t $.Lang (printf "role_%s" .LatestDecision.OfficerRole)}} — {{t $.Lang (printf "status_%s" .LatestDecision.Decision)}} — {{.LatestDecision.CreatedAt}}{{if .LatestDecision.Note}} · {{.LatestDecision.Note}}{{end}}{{if .LatestDecision.Reason}} · {{.LatestDecision.Reason}}{{end}}</div>{{end}}{{if eq .Status "pending"}}<form method="post" action="/api/member/withdrawal-requests/{{.ID}}/cancel" hx-post="/api/member/withdrawal-requests/{{.ID}}/cancel"><button class="button-secondary" type="submit">{{t $.Lang "cancel"}}</button></form>{{end}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_withdrawal_requests")}}
        {{end}}
      </article>
    </section>
{{template "member-shell-end" .}}
{{end}}

{{define "member-loan-requests"}}
{{template "member-shell-start" .}}
    {{if .OutstandingLoans}}
    <section class="panel loan-warning" role="alert">
      <h2>{{t .Lang "outstanding_loans"}} — Rp {{nominal .TotalOutstanding}}</h2>
      <p>{{t .Lang "loan_request_outstanding_notice"}}</p>
      <div class="loan-card-grid">
      {{range .OutstandingLoans}}
        <article class="loan-summary-card {{if .IsOverdue}}loan-overdue{{end}}">
          <header><strong>{{t $.Lang (printf "status_%s" .Status)}}</strong>{{if .IsOverdue}}<span>{{t $.Lang "overdue"}}</span>{{end}}</header>
          <dl>
            <div><dt>{{t $.Lang "loan_type"}}</dt><dd>{{template "loan-type-label" (dict "Lang" $.Lang "LoanType" .LoanType "LegacyTerms" .LegacyTerms)}}</dd></div>
            <div><dt>{{t $.Lang "remaining_balance"}}</dt><dd>Rp {{nominal .RemainingBalance}}</dd></div>
            <div><dt>{{t $.Lang "approved_principal"}}</dt><dd>Rp {{nominal .ApprovedAmount}}</dd></div>
            <div><dt>{{t $.Lang "start_date"}}</dt><dd>{{.StartDate}}</dd></div>
			<div><dt>{{t $.Lang "monthly_admin_fee"}}</dt><dd>Rp {{nominal .MonthlyAdminFee}}</dd></div>
            <div><dt>{{t $.Lang "next_due_date"}}</dt><dd>{{.NextDueDate}}</dd></div>
            <div><dt>{{t $.Lang "final_due_date"}}</dt><dd>{{.FinalDueDate}}</dd></div>
          </dl>
        </article>
      {{end}}
      </div>
    </section>
    {{end}}
    <section class="two-column">
      <article class="panel">
        <h2>{{t .Lang "submit_loan_request"}}</h2>
        <form method="post" action="/api/member/loan-requests" hx-post="/api/member/loan-requests" hx-target="#loan-request-error" hx-swap="innerHTML" data-loan-fee-preview data-monthly-admin-fee-label="{{t .Lang "monthly_admin_fee"}}" data-total-admin-fee-label="{{t .Lang "total_admin_fee"}}" data-total-obligation-label="{{t .Lang "total_obligation"}}" data-rupiah-group="{{if eq .Lang "id"}}.{{else}},{{end}}">
          <label>{{t .Lang "loan_type"}} <select name="loan_type" data-loan-type required><option value="">{{t .Lang "select_loan_type"}}</option><option value="regular">{{t .Lang "loan_type_regular"}}</option><option value="secondary_goods">{{t .Lang "loan_type_secondary_goods"}}</option><option value="goods_purchase_paylater">{{t .Lang "loan_type_goods_purchase_paylater"}}</option></select></label>
		  <label>{{t .Lang "requested_amount"}}
            <input name="requested_amount" type="text" inputmode="numeric" placeholder="Rp 0" data-rupiah-input data-loan-amount data-rupiah-group="{{if eq .Lang "id"}}.{{else}},{{end}}" data-rupiah-invalid="{{t .Lang "error_invalid_rupiah_amount"}}" data-rupiah-max="200000000" data-rupiah-max-invalid="{{t .Lang "error_loan_amount_limit"}}" aria-describedby="loan-request-amount-hint" aria-errormessage="loan-request-amount-error" required>
            <small id="loan-request-amount-hint">{{t .Lang "loan_amount_limit_hint"}}</small>
            <small id="loan-request-amount-error" class="form-error-message" aria-live="polite" hidden></small>
          </label>
		  <label>{{t .Lang "duration_months"}} <input name="duration_months" type="number" min="1" max="24" data-loan-duration required></label>
          <p class="loan-fee-preview" data-loan-fee-output aria-live="polite" hidden></p>
		  <label>{{t .Lang "purpose"}} <input name="purpose" required></label>
          <button type="submit">{{t .Lang "submit_loan_request"}}</button>
        </form>
{{template "form-error" (dict "ID" "loan-request-error")}}
      </article>
      <article class="panel">
        <h2>{{t .Lang "request_history"}}</h2>
        {{if .LoanRequests}}
{{template "table-open" .}}
          <thead>
            <tr>
              <th>{{t $.Lang "amount"}}</th>
              <th>{{t $.Lang "loan_type"}}</th>
              <th>{{t $.Lang "duration"}}</th>
              <th>{{t $.Lang "status"}}</th>
              <th>{{t $.Lang "purpose"}}</th>
              <th>{{t $.Lang "review"}}</th>
            </tr>
          </thead>
          <tbody>
            {{range .LoanRequests}}
            <tr>
              <td>{{nominal .RequestedAmount}}</td>
              <td>{{template "loan-type-label" (dict "Lang" $.Lang "LoanType" .LoanType "LegacyTerms" .LegacyTerms)}}</td>
              <td>{{.DurationMonths}}</td>
              <td>{{template "status-badge" (dict "Lang" $.Lang "Status" .Status)}}</td>
              <td>{{.Purpose}}</td>
              <td>{{if .CurrentApprovalStage}}{{t $.Lang "awaiting"}} {{t $.Lang (printf "role_%s" .CurrentApprovalStage)}}{{end}}{{if .LatestDecision}}<div>{{t $.Lang (printf "role_%s" .LatestDecision.OfficerRole)}} — {{t $.Lang (printf "status_%s" .LatestDecision.Decision)}} — {{.LatestDecision.CreatedAt}}{{if .LatestDecision.Note}} · {{.LatestDecision.Note}}{{end}}{{if .LatestDecision.Reason}} · {{.LatestDecision.Reason}}{{end}}</div>{{end}}{{if eq .Status "pending"}}<form method="post" action="/api/member/loan-requests/{{.ID}}/cancel" hx-post="/api/member/loan-requests/{{.ID}}/cancel"><button class="button-secondary" type="submit">{{t $.Lang "cancel"}}</button></form>{{end}}</td>
            </tr>
            {{end}}
          </tbody>
{{template "table-close" .}}
        {{else}}
{{template "empty-state" (t .Lang "no_loan_requests")}}
        {{end}}
      </article>
    </section>
{{template "member-shell-end" .}}
{{end}}
